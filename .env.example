# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Next Auth
# You can generate a new secret on the command line with:
# npx auth secret
# https://next-auth.js.org/configuration/options#secret
AUTH_SECRET=""

# Next Auth Discord Provider
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# Prisma
# https://www.prisma.io/docs/reference/database-reference/connection-urls#env
DATABASE_URL="postgresql://postgres:password@localhost:5432/orbit-ai"

# LEGACY OpenClaw (retiré du produit visible — backend en migration vers AI Review Engine)
# Ne plus activer côté UI. Variables conservées temporairement pour routes legacy.
# OPENCLAW_GATEWAY_URL="http://127.0.0.1:18789"
# OPENCLAW_GATEWAY_TOKEN=""
# OPENCLAW_AGENT_ID="main"
# NEXT_PUBLIC_OPENCLAW_ENABLED="false"

# LEGACY — Worker sync OpenClaw (sera supprimé Phase D)
# OPENCLAW_LOGS_DIR="logs"
# OPENCLAW_EXCHANGE_DIR="data/exchange"
# OPENCLAW_SKILLS_DIR="data/skills"
# OPENCLAW_DEFAULT_USER_ID=""
# CRON_SECRET=""
# OPENCLAW_SYNC_SECRET=""
# LEGACY — préférer REVIEW_POLLING_TOKEN (supprimé Phase D)
# OPENCLAW_VALIDATION_STATUS_TOKEN=""
# Token polling GET /api/review/status (Authorization: Bearer …)
# REVIEW_POLLING_TOKEN=""

# Tracker d'activité (script Python) — secret HMAC min. 32 caractères
# Générer : openssl rand -base64 32
# TRACKER_SIGNING_SECRET=""

# Administration clients (emails séparés par des virgules)
# ORBIT_ADMIN_EMAILS="contact@alphasys.tech,admin@example.com"

# OpenWeatherMap — météo RégiAire (Verdict + header station)
# https://home.openweathermap.org/api_keys
# Préférer OWM_API_KEY (serveur). NEXT_PUBLIC_OWM_API_KEY reste accepté en fallback.
OWM_API_KEY=""
